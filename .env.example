# Web app (Vite) — safe to expose to the browser (VITE_ prefix).
# Point the dashboard at the deployed app API. Leave unset to run in preview
# mode (sample data, no backend).
VITE_API_URL=

# ---------------------------------------------------------------------------
# Backend secrets are NOT set here in deployed environments — they live in AWS
# Secrets Manager (see packages/infra). Listed for local reference only:
#   REPLIERS_API_KEY        Repliers REPLIERS-API-KEY (server-side only)
#   CLAUDE_API_KEY          Anthropic API key (research engine, Phase 2)
#   CLUSTER_ARN             Aurora cluster ARN          (set by CDK on the Lambdas)
#   DB_SECRET_ARN           Aurora creds secret ARN     (set by CDK)
#   DB_NAME                 forge
#   REPLIERS_SECRET_ARN     Repliers key secret ARN     (set by CDK)
#   USER_POOL_ID            Cognito user pool id        (from amplify_outputs.json)
#   USER_POOL_CLIENT_ID     Cognito app client id       (from amplify_outputs.json)
#   SES_FROM                digest sender (Phase 3)
#   SLACK_WEBHOOK           optional digest channel (Phase 3)
